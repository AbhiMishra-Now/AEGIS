# =============================================================================
# AEGIS Sentinel — Backend Environment Variables
# =============================================================================
#
# This file is the ONLY place the backend reads secrets. It is loaded once at
# process startup via pydantic-settings, and held in memory. The frontend
# NEVER sees any value from this file — all values are masked before any
# HTTP response is constructed.
#
# DO NOT COMMIT A REAL .env FILE TO VERSION CONTROL.
# Copy this file to .env and fill in your values.
# =============================================================================

# ---- Server -----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---- Frontend trust list (CORS) ---------------------------------------------
# Comma-separated list of origins allowed to call the API. Locked to the
# Next.js / Vite frontend.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Arize Phoenix (MCP + trace store)
# =============================================================================
# Get from: https://app.phoenix.arize.com → Settings → API Keys
ARIZE_API_KEY=arize_phx_REPLACE_ME
# Phoenix UI + REST endpoint
PHOENIX_URL=https://app.phoenix.arize.com
# The Phoenix project the worker should poll
PHOENIX_PROJECT=aegis-prod
# Optional: explicit MCP endpoint if different from PHOENIX_URL
PHOENIX_MCP_URL=

# =============================================================================
# Google Cloud (Vertex AI Agent Builder)
# =============================================================================
GCP_PROJECT_ID=my-gcp-project
GCP_LOCATION=us-central1
# The Vertex AI Agent Builder agent to monitor + patch
AGENT_ID=research-agent
# Path to a service-account JSON on the BACKEND host. Never send this to the
# browser; the AEGIS server loads it once with google.oauth2.
GCP_SERVICE_ACCOUNT_JSON_PATH=/etc/aegis/sa.json

# =============================================================================
# Gemini (LLM-as-judge)
# =============================================================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyREPLACE_ME
JUDGE_MODEL=gemini-2.5-pro

# =============================================================================
# Behavioral defaults (overridable from /api/settings)
# =============================================================================
# Heuristic: a "loop" is the same tool called this many times in the window.
LOOP_TOOL_THRESHOLD=3
LOOP_WINDOW_SECONDS=10
# Cost-spike guard: heal if per-minute spend exceeds this.
COST_SPIKE_THRESHOLD=0.5
# Token budget: pause an agent if cumulative spend exceeds this in a window.
TOKEN_BUDGET_PER_HOUR=200000
# Whether new spans are pushed to the live WebSocket stream.
LIVE_STREAM_ENABLED=true
# Whether the AEGIS engine is allowed to patch prompts without human approval.
AUTO_HEAL_ENABLED=true

# =============================================================================
# Worker
# =============================================================================
# How often the worker polls Phoenix for new spans (seconds).
WORKER_POLL_INTERVAL=5
# Max spans fetched per poll.
WORKER_POLL_LIMIT=200
